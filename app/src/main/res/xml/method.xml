<?xml version="1.0" encoding="utf-8"?>
<!-- IME subtypes: the three input modes from SPEC.md §5. Wired to real layouts in Phase 1. -->
<input-method xmlns:android="http://schemas.android.com/apk/res/android"
    android:settingsActivity="com.kinetic.keyboard.MainActivity">

    <subtype
        android:label="@string/subtype_bangla_unijoy"
        android:imeSubtypeLocale="bn_BD"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="false" />

    <subtype
        android:label="@string/subtype_bangla_phonetic"
        android:imeSubtypeLocale="bn_BD"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true" />

    <subtype
        android:label="@string/subtype_english"
        android:imeSubtypeLocale="en_US"
        android:imeSubtypeMode="keyboard"
        android:isAsciiCapable="true" />

</input-method>
